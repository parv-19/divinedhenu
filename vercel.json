{
  "services": {
    "frontend": {
      "root": ".",
      "framework": "vite",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "installCommand": "npm install"
    },
    "backend": {
      "root": "backend",
      "framework": "express",
      "buildCommand": "npm install",
      "startCommand": "npm start"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend"
    },
    {
      "src": "/(.*)",
      "dest": "frontend"
    }
  ]
}
